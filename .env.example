# Discord OAuth (aplicación del portal)
AUTH_SECRET=genera_una_clave_larga
AUTH_DISCORD_ID=tu_client_id
AUTH_DISCORD_SECRET=tu_client_secret
AUTH_URL=http://localhost:3001
AUTH_TRUST_HOST=true
DISCORD_GUILD_ID=tu_guild_id

# API privada de EyedBot; la clave debe coincidir en ambos proyectos
EYEDBOT_API_URL=http://localhost:3000
COMMUNITY_API_KEY=genera_otra_clave_larga

# MySQL privado de EyedComun
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=eyedcomun
DB_USER=eyedcomun
DB_PASSWORD=contraseña_local

# 32 bytes en base64: openssl rand -base64 32
MEDIA_ENCRYPTION_KEY=pega_aqui_una_clave_base64
MEDIA_ENCRYPTION_KEY_VERSION=1
MEDIA_STORAGE_PATH=./data/uploads

# Docker/Portainer (raíz persistente en el SSD)
EYEDCOMUN_DATA_ROOT=/srv/dev-disk-by-uuid-94f2a4b3-1a12-41f9-b0ee-e78aa049c7ea/SSD512/docker/eyedcomun
EYEDCOMUN_PORT=3001
